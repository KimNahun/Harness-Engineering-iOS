{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/block-direct-write.js",
            "description": "프로젝트 폴더에 새 Swift 파일 직접 생성 차단 (/harness 사용 유도)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/swift-syntax-check.js",
            "description": "Swift 문법 검증 (swiftc -parse)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/pre-commit-build.js",
            "statusMessage": "빌드 검증 + 커밋 중..."
          }
        ]
      }
    ]
  }
}
